HOST=0.0.0.0
PORT=8080

# Public URL of your frontend (GitHub Pages)
ALLOWED_ORIGINS=https://phindagijimana.github.io

# Email provider: Resend
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=licenses@inzira-labs.com

# License integrity signature secret
LICENSE_SIGNING_SECRET=change-me

# GitHub private release source
GITHUB_TOKEN=ghp_xxxxx
GITHUB_REPO=phindagijimana/neuroinsight_research
GITHUB_RELEASE_TAG=latest

# Optional comma-separated allowlist of asset names to expose.
# If empty, common installer extensions are used.
ASSET_NAME_ALLOWLIST=

# Public base URL of this service for email link generation
DOWNLOAD_LINK_BASE_URL=https://license.inzira-labs.com

# Time-limited secure download token window
DOWNLOAD_TOKEN_TTL_HOURS=24

# Optional fallback URL shown in email when no assets are found
NIR_RELEASE_URL=https://github.com/phindagijimana/neuroinsight_research/releases
