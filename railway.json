{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd license-service && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd license-service && uvicorn main:app --host 0.0.0.0 --port ${PORT:-8080}",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
